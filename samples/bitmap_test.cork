// Test: bitmap plotting stdlib
import "stdlib/bitmap.cork";

entry scene Test {
    hardware {
        mode: bitmap;
        border: Color.black;
        background: Color.black;
    }

    enter {
        clearBitmap:;
        setBitmapColors: Color.green bg: Color.black;

        // Individual pixels at known positions
        plotPixel: 160 y: 100;
        plotPixel: 161 y: 100;
        plotPixel: 162 y: 100;
        plotPixel: 163 y: 100;
        plotPixel: 160 y: 101;
        plotPixel: 160 y: 102;
        plotPixel: 160 y: 103;

        // Diagonal line
        byte i = 0;
        while (i < 40) {
            word px = 40;
            px += i * 2;
            plotPixel: px y: 40 + i;
            i += 1;
        }

        // Another diagonal
        i = 0;
        while (i < 40) {
            word px = 200;
            px += i * 2;
            plotPixel: px y: 140 - i;
            i += 1;
        }

        // Short h-line (just 20 pixels)
        bitmapHLine: 10 from: 10 to: 30;
    }

    frame { }
}
