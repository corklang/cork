{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cork",
  "scopeName": "source.cork",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#sprite-patterns" },
    { "include": "#import-statement" },
    { "include": "#scene-declaration" },
    { "include": "#struct-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#const-declaration" },
    { "include": "#sprite-block" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#method-selectors" },
    { "include": "#color-constants" },
    { "include": "#hardware-registers" },
    { "include": "#language-constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cork",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cork",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cork",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cork",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "sprite-patterns": {
      "name": "string.other.sprite-pattern.cork",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "comment.sprite.transparent.cork",
          "match": "\\."
        },
        {
          "name": "variable.parameter.sprite.hires.cork",
          "match": "#"
        },
        {
          "name": "support.class.sprite.mc0.cork",
          "match": "1"
        },
        {
          "name": "string.other.sprite.mc-sprite.cork",
          "match": "2"
        },
        {
          "name": "keyword.control.sprite.mc1.cork",
          "match": "3"
        }
      ]
    },

    "import-statement": {
      "patterns": [
        {
          "match": "\\b(import)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "string.quoted.double.cork" }
          }
        },
        {
          "match": "\\b(import)\\s+([A-Z]\\w*(?:\\.[A-Z]\\w*)+)",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "entity.name.type.module.cork" }
          }
        }
      ]
    },

    "scene-declaration": {
      "patterns": [
        {
          "match": "\\b(entry)\\s+(scene)\\s+([A-Z]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "keyword.declaration.cork" },
            "3": { "name": "entity.name.type.scene.cork" }
          }
        },
        {
          "match": "\\b(scene)\\s+([A-Z]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "entity.name.type.scene.cork" }
          }
        },
        {
          "comment": "go SceneName transition",
          "match": "\\b(go)\\s+([A-Z]\\w*)",
          "captures": {
            "1": { "name": "keyword.control.cork" },
            "2": { "name": "entity.name.type.scene.cork" }
          }
        }
      ]
    },

    "struct-declaration": {
      "match": "\\b(struct)\\s+([A-Z]\\w*)",
      "captures": {
        "1": { "name": "keyword.declaration.cork" },
        "2": { "name": "entity.name.type.struct.cork" }
      }
    },

    "enum-declaration": {
      "patterns": [
        {
          "match": "\\b(flags)\\s+(enum)\\s+([A-Z]\\w*)(?:\\s*:\\s*(byte|sbyte|word|sword))?",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "keyword.declaration.cork" },
            "3": { "name": "entity.name.type.enum.cork" },
            "4": { "name": "storage.type.cork" }
          }
        },
        {
          "match": "\\b(enum)\\s+([A-Z]\\w*)(?:\\s*:\\s*(byte|sbyte|word|sword))?",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "entity.name.type.enum.cork" },
            "3": { "name": "storage.type.cork" }
          }
        }
      ]
    },

    "const-declaration": {
      "patterns": [
        {
          "match": "\\b(const)\\s+(byte|sbyte|word|sword|fixed|sfixed|bool|string)(?:\\[(\\d+)\\])?",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "storage.type.cork" },
            "3": { "name": "constant.numeric.decimal.cork" }
          }
        },
        {
          "match": "\\b(const)\\s+([A-Z_]\\w*)\\s*=",
          "captures": {
            "1": { "name": "keyword.declaration.cork" },
            "2": { "name": "variable.other.constant.cork" }
          }
        }
      ]
    },

    "sprite-block": {
      "match": "\\b(sprite)\\s+(\\d+)\\s+(\\w+)",
      "captures": {
        "1": { "name": "keyword.other.hardware.cork" },
        "2": { "name": "constant.numeric.decimal.cork" },
        "3": { "name": "variable.other.sprite.cork" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cork",
          "match": "\\b(if|else|while|for|in|switch|case|default|fallthrough|break|continue|return|go)\\b"
        },
        {
          "name": "keyword.other.lifecycle.cork",
          "match": "\\b(hardware|enter|frame|relaxed|raster|exit)\\b"
        },
        {
          "name": "keyword.declaration.cork",
          "match": "\\b(entry|scene|struct|enum|flags|const|import)\\b"
        },
        {
          "name": "keyword.other.cork",
          "match": "\\b(as)\\b"
        },
        {
          "name": "keyword.other.hardware.cork",
          "match": "\\b(sprite)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.cork",
      "match": "\\b(byte|sbyte|word|sword|fixed|sfixed|bool|string|var|charset|music|sound|tilemap)\\b"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.cork",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.float.cork",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.decimal.cork",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.cork",
          "match": "\\|\\||&&|!"
        },
        {
          "name": "keyword.operator.comparison.cork",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.cork",
          "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|="
        },
        {
          "name": "keyword.operator.cork",
          "match": "~|\\+|-|\\*|/|%|&|\\||\\^|<<|>>"
        }
      ]
    },

    "method-selectors": {
      "patterns": [
        {
          "comment": "Method definition — name followed by colon and open brace (with optional return type)",
          "match": "\\b(?:byte|sbyte|word|sword|fixed|sfixed|bool)\\s+(\\w+:)\\s*(?:\\(|\\{)",
          "captures": {
            "1": { "name": "entity.name.function.cork" }
          }
        },
        {
          "comment": "Method definition — name followed by colon and open brace (no return type)",
          "match": "^\\s*(\\w+:)\\s*\\{",
          "captures": {
            "1": { "name": "entity.name.function.cork" }
          }
        },
        {
          "comment": "Keyword argument labels in method calls and definitions",
          "match": "\\b(\\w+)(:)(?!:)",
          "captures": {
            "1": { "name": "entity.name.function.cork" },
            "2": { "name": "punctuation.separator.method.cork" }
          }
        }
      ]
    },

    "color-constants": {
      "match": "\\b(Color)\\.(black|white|red|cyan|purple|green|blue|yellow|orange|brown|lightRed|darkGrey|grey|lightGreen|lightBlue|lightGrey)\\b",
      "captures": {
        "1": { "name": "support.type.color.cork" },
        "2": { "name": "support.constant.color.cork" }
      }
    },

    "hardware-registers": {
      "match": "\\b(joystick)\\.(port1|port2)\\.(left|right|up|down|fire)\\b",
      "captures": {
        "1": { "name": "support.variable.hardware.cork" },
        "2": { "name": "support.variable.hardware.cork" },
        "3": { "name": "support.variable.hardware.cork" }
      }
    },

    "language-constants": {
      "name": "constant.language.cork",
      "match": "\\b(true|false)\\b"
    },

    "identifiers": {
      "patterns": [
        {
          "comment": "Type name in variable declaration position (capitalized)",
          "match": "\\b([A-Z]\\w*)(?=\\s+\\w)",
          "captures": {
            "1": { "name": "entity.name.type.struct.cork" }
          }
        },
        {
          "comment": "Enum member access: EnumName.member",
          "match": "\\b([A-Z]\\w*)\\.(\\w+)\\b",
          "captures": {
            "1": { "name": "entity.name.type.enum.cork" },
            "2": { "name": "variable.other.enummember.cork" }
          }
        }
      ]
    }
  }
}
