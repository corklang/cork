{
  "name": "cork-lang",
  "displayName": "Cork",
  "description": "Language support for Cork, a C64 game programming language",
  "version": "0.1.0",
  "publisher": "cork-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cork",
        "aliases": [
          "Cork",
          "cork"
        ],
        "extensions": [
          ".cork"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/cork-icon.svg",
          "dark": "./icons/cork-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "cork",
        "scopeName": "source.cork",
        "path": "./syntaxes/cork.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cork",
        "path": "./snippets/cork.json"
      }
    ]
  }
}
